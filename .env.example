# Snowflake connection settings — copy this file to `.env` and fill in real values.
# The real `.env` is gitignored and must NEVER be committed.

SNOWFLAKE_ACCOUNT=abc12345.us-east-1   # the part before .snowflakecomputing.com
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=SHOPSTREAM_ROLE
SNOWFLAKE_WAREHOUSE=SHOPSTREAM_WH
SNOWFLAKE_DATABASE=SHOPSTREAM
SNOWFLAKE_SCHEMA=RAW
